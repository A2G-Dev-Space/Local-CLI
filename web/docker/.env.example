# Database
POSTGRES_DB=local_web
POSTGRES_USER=local_web
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://local_web:changeme@postgres:5432/local_web

# Redis
REDIS_URL=redis://redis:6379

# Auth
JWT_SECRET=changeme-jwt-secret

# LLM Configuration
LLM_ENDPOINT_URL=http://localhost:11434/v1
LLM_API_KEY=
LLM_MODEL_ID=qwen2.5-coder:32b

# Session containers
SESSION_IMAGE=local-web-session:latest
SESSION_NETWORK=local-web-network
SESSION_CPU_LIMIT=0.5
SESSION_MEMORY_LIMIT=268435456
SESSION_PORT_START=10000

# Frontend
WEB_APP_URL=http://localhost:7090
CORS_ORIGIN=*

# Server
PORT=3000
PROXY_PORT=7090

# Environment label
ENV_LABEL=LOCAL
